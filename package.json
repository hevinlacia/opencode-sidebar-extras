{
  "name": "opencode-sidebar-extras",
  "version": "0.1.0",
  "description": "OpenCode TUI sidebar extras: small reusable widgets (session_id, handoff status, ...)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tui": {
      "import": "./src/index.tsx",
      "config": {
        "enabled": true
      }
    }
  },
  "files": [
    "dist",
    "src",
    "install.mjs",
    "README.md"
  ],
  "bin": {
    "opencode-sidebar-extras": "install.mjs"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "tui",
    "sidebar",
    "session"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.14.0",
    "@opencode-ai/sdk": ">=1.14.0",
    "@opentui/core": ">=0.2.0",
    "@opentui/solid": ">=0.2.0",
    "solid-js": ">=1.9.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.14.50",
    "@opencode-ai/sdk": "^1.14.50",
    "typescript": "^5.8.0"
  }
}
